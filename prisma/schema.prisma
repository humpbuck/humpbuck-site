generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  firstName               String?
  lastName                String?
  displayName             String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  accounts                Account[]
  affiliateApplications   AffiliateApplication[]
  affiliateCouponRequests AffiliateCouponRequest[]
  affiliateProfile        AffiliateProfile?
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  productReviews          ProductReview[]
  paymentMethods          SavedPaymentMethod[]
  sessions                Session[]
  addresses               UserAddress[]
  visitorSessions         VisitorSession[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id                         String                     @id @default(cuid())
  userId                     String?
  email                      String
  status                     String
  provider                   String
  providerRef                String?
  totalCents                 Int
  currency                   String                     @default("usd")
  billingJson                String?
  shippingJson               String?
  orderNotes                 String?
  carrier                    String?
  trackingNumber             String?
  merchantOrderCode          String?
  trafficSource              String                     @default("unknown")
  merchantNotifySentAt       DateTime?
  customerShippedEmailSentAt DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  refundReason               String?
  refundAmountCents          Int?
  refundedAt                 DateTime?
  couponCode                 String?
  discountCents              Int                        @default(0)
  affiliateAttribution       String?
  affiliateId                String?
  affiliatePid               String?
  shippedAt                  DateTime?
  deliveredAt                DateTime?
  deliveryConfirmedBy        String?
  items                      OrderItemSnapshot[]
  affiliateCommission        AffiliateCommissionLedger?
  affiliate                  AffiliateProfile?          @relation(fields: [affiliateId], references: [id])
  user                       User?                      @relation(fields: [userId], references: [id])

  @@index([deletedAt])
  @@index([affiliateId, createdAt])
  @@index([status, shippedAt])
}

model OrderItemSnapshot {
  id                  String   @id @default(cuid())
  orderId             String
  productSlug         String
  productName         String
  productImage        String?
  variantId           String?
  variantLabel        String?
  variantImage        String?
  qty                 Int
  unitPriceCents      Int
  lineTotalCents      Int
  currency            String   @default("usd")
  productSnapshotJson String?
  createdAt           DateTime @default(now())

  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productSlug])
  @@index([variantId])
}

model EmailMarketingPreference {
  id               String   @id @default(cuid())
  email            String   @unique
  unsubscribeToken String   @unique
  marketingOptOut  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserAddress {
  id         String   @id @default(cuid())
  userId     String
  type       String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  brand     String
  last4     String
  expMonth  Int?
  expYear   Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductInventory {
  id                String   @id @default(cuid())
  productSlug       String
  variantId         String   @default("")
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt

  @@unique([productSlug, variantId])
  @@index([productSlug])
}

model CatalogProduct {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  seriesSlug       String
  categoryLabel    String
  shortDescription String
  description      String
  price            Float
  compareAtPrice   Float?
  image            String
  status           String   @default("active")
  inStock          Boolean  @default(true)
  highlightsJson   String   @default("[]")
  specsJson        String   @default("[]")
  galleryJson      String   @default("[]")
  detailJson       String   @default("[]")
  variantsJson     String   @default("[]")
  promoVideoJson   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProductReview {
  id                String                @id @default(cuid())
  userId            String
  orderId           String
  productSlug       String
  rating            Int
  body              String
  imageUrlsJson     String                @default("[]")
  merchantReply     String?
  merchantRepliedAt DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  appends           ProductReviewAppend[]

  @@unique([userId, orderId, productSlug])
  @@index([productSlug])
}

model ProductReviewAppend {
  id            String        @id @default(cuid())
  reviewId      String
  body          String
  imageUrlsJson String        @default("[]")
  createdAt     DateTime      @default(now())
  review        ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
}

model VisitorSession {
  id            String         @id @default(cuid())
  sessionKey    String         @unique
  userId        String?
  firstReferrer String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  landingPath   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  country       String?
  city          String?
  deviceType    String?
  browser       String?
  lastSeenAt    DateTime       @default(now())
  events        VisitorEvent[]
  user          User?          @relation(fields: [userId], references: [id])
}

model VisitorEvent {
  id          String         @id @default(cuid())
  sessionId   String
  type        String
  path        String?
  productSlug String?
  orderId     String?
  source      String?
  metaJson    String?
  createdAt   DateTime       @default(now())
  session     VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([type, createdAt])
  @@index([productSlug, createdAt])
}

model Coupon {
  id             String            @id @default(cuid())
  code           String            @unique
  amountOffCents Int
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  quantity       Int               @default(1)
  usedCount      Int               @default(0)
  affiliateId    String?
  affiliate      AffiliateProfile? @relation(fields: [affiliateId], references: [id])

  @@index([isActive, startsAt, endsAt])
  @@index([affiliateId])
}

model AffiliateTier {
  id              String             @id @default(cuid())
  name            String             @unique
  commissionType  String             @default("percent")
  commissionValue Float              @default(0)
  isDefault       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  profiles        AffiliateProfile[]
}

model AffiliateProfile {
  id                 String                      @id @default(cuid())
  userId             String                      @unique
  displayName        String?
  status             String                      @default("active")
  riskFlag           Boolean                     @default(false)
  tierId             String?
  whitelist          Boolean                     @default(false)
  blacklist          Boolean                     @default(false)
  paymentInfoPending Boolean                     @default(true)
  notes              String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  pid                String?                     @unique
  payoutEmail        String?
  whatsapp           String?                     @map("payoutWhatsapp")
  payoutMethod       String?
  payoutAccount      String?
  payoutVerifiedAt   DateTime?
  payoutVerifiedBy   String?
  applications       AffiliateApplication[]
  commissionLedgers  AffiliateCommissionLedger[]
  couponRequests     AffiliateCouponRequest[]
  tier               AffiliateTier?              @relation(fields: [tierId], references: [id])
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupons            Coupon[]
  orders             Order[]

  @@index([status])
  @@index([blacklist, whitelist])
}

model AffiliateCommissionLedger {
  id                      String           @id @default(cuid())
  affiliateId             String
  orderId                 String           @unique
  orderTotalCents         Int
  commissionType          String
  commissionValue         Float
  commissionCents         Int
  holdDays                Int              @default(30)
  eligibleAt              DateTime
  status                  String           @default("pending")
  reversedCommissionCents Int              @default(0)
  reversalReason          String?
  reversedAt              DateTime?
  paidAt                  DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  payoutBatchId           String?
  payoutTxnRef            String?
  paidNote                String?
  paidEmailSentAt         DateTime?
  affiliate               AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  order                   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([affiliateId, status, eligibleAt])
}

model AffiliateApplication {
  id              String            @id @default(cuid())
  userId          String
  affiliateId     String?
  socialLinksJson String            @default("[]")
  followerCount   Int?
  about           String?
  status          String            @default("pending")
  riskReason      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  affiliate       AffiliateProfile? @relation(fields: [affiliateId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AffiliateCouponRequest {
  id          String            @id @default(cuid())
  userId      String
  affiliateId String?
  status      String            @default("pending")
  requestedAt DateTime          @default(now())
  handledAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  affiliate   AffiliateProfile? @relation(fields: [affiliateId], references: [id])
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt])
  @@index([userId, requestedAt])
}

model AdminInboxMessage {
  id          String    @id @default(cuid())
  category    String
  status      String    @default("pending")
  sourceEmail String?
  payloadJson String    @default("{}")
  createdAt   DateTime  @default(now())
  handledAt   DateTime?
  updatedAt   DateTime  @updatedAt
  dedupeKey   String?   @unique

  @@index([category, status, createdAt])
  @@index([status, createdAt])
}

model AdminInboxReadCursor {
  id        String   @id @default(cuid())
  category  String   @unique
  readAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoTutorial {
  productSlug String   @id
  title       String
  url         String
  aspectRatio String   @default("9:16")
  updatedAt   DateTime @default(now())
  sortOrder   Int      @default(9999)
  youtubeUrl  String   @default("")
}

model WholesaleListing {
  id          String   @id @default(cuid())
  modelNumber String   @default("")
  description String   @default("")
  priceUsd    Float    @default(0)
  mediaJson   String   @default("[]")
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sortOrder])
}
