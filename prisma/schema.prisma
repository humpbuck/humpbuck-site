generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  displayName   String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     UserAddress[]
  paymentMethods SavedPaymentMethod[]
  passwordResetTokens PasswordResetToken[]
  productReviews ProductReview[]
  visitorSessions VisitorSession[]
  affiliateProfile AffiliateProfile?
  affiliateApplications AffiliateApplication[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  affiliateId    String?
  affiliate      AffiliateProfile? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  affiliateCommission AffiliateCommissionLedger?
  affiliatePid   String?
  affiliateAttribution String?
  email          String
  status         String
  provider       String
  providerRef    String?
  totalCents     Int
  couponCode     String?
  discountCents  Int      @default(0)
  currency       String   @default("usd")
  itemsJson      String
  billingJson    String? // card / invoice; may differ from shipping
  shippingJson   String?
  orderNotes     String? // optional message from checkout (delivery instructions, etc.)
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  deliveryConfirmedBy String?
  // Optional merchant-facing label (emails / account). Falls back to id tail when null.
  merchantOrderCode String?
  // First-touch traffic: utm_source or inferred referrer (google, direct, …)
  trafficSource  String   @default("unknown")
  merchantNotifySentAt DateTime?
  // Customer shipped notification email sent at (Brevo); idempotent.
  customerShippedEmailSentAt DateTime?
  // Soft-delete: when set, order is hidden from default queries.
  deletedAt      DateTime?
  // Refund tracking
  refundReason   String?
  refundAmountCents Int?
  refundedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([deletedAt])
  @@index([affiliateId, createdAt])
  @@index([status, shippedAt])
}

// Promo/newsletter opt-out per email + one-click unsubscribe token.
model EmailMarketingPreference {
  id                 String   @id @default(cuid())
  email              String   @unique
  unsubscribeToken String   @unique
  marketingOptOut    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserAddress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  brand     String
  last4     String
  expMonth  Int?
  expYear   Int?
  createdAt DateTime @default(now())
}

// Product inventory — quantity tracking per product+variant.
// `variantId` is "" for products without variants (product-level stock).
model ProductInventory {
  id               String   @id @default(cuid())
  productSlug      String
  variantId        String   @default("")
  quantity         Int      @default(0)
  lowStockThreshold Int     @default(5)
  updatedAt        DateTime @updatedAt

  @@unique([productSlug, variantId])
  @@index([productSlug])
}

// Admin-managed product catalog (editable in admin panel).
model CatalogProduct {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  seriesSlug       String
  categoryLabel    String
  shortDescription String
  description      String
  price            Float
  compareAtPrice   Float?
  image            String
  inStock          Boolean  @default(true)
  highlightsJson   String   @default("[]")
  specsJson        String   @default("[]")
  galleryJson      String   @default("[]")
  detailJson       String   @default("[]")
  variantsJson     String   @default("[]")
  promoVideoJson   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Buyer review; images on R2 under reviews/{productSlug}/
model ProductReview {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String
  productSlug   String
  rating        Int
  body          String
  imageUrlsJson String   @default("[]")
  merchantReply   String?
  merchantRepliedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appends       ProductReviewAppend[]

  @@unique([userId, orderId, productSlug])
  @@index([productSlug])
}

// Buyer follow-up (追加) on an existing review, same product, optional photos.
model ProductReviewAppend {
  id            String   @id @default(cuid())
  reviewId      String
  review        ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  body          String
  imageUrlsJson String   @default("[]")
  createdAt     DateTime @default(now())

  @@index([reviewId, createdAt])
}

// Anonymous or logged-in visitor session for onsite analytics.
model VisitorSession {
  id            String   @id @default(cuid())
  sessionKey    String   @unique
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstReferrer String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  country       String?
  city          String?
  deviceType    String?
  browser       String?
  landingPath   String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        VisitorEvent[]
}

// Event stream per visitor session: page/product/cart/checkout lifecycle.
model VisitorEvent {
  id          String         @id @default(cuid())
  sessionId   String
  session     VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        String
  path        String?
  productSlug String?
  orderId     String?
  source      String?
  metaJson    String?
  createdAt   DateTime       @default(now())

  @@index([sessionId, createdAt])
  @@index([type, createdAt])
  @@index([productSlug, createdAt])
}

// Admin coupon codes (fixed amount off in cents) with active date range.
model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  affiliateId    String?
  affiliate      AffiliateProfile? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  amountOffCents Int
  quantity       Int      @default(1)
  usedCount      Int      @default(0)
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@index([affiliateId])
}

model AffiliateTier {
  id              String   @id @default(cuid())
  name            String   @unique
  commissionType  String   @default("percent")
  commissionValue Float    @default(0)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profiles        AffiliateProfile[]
}

model AffiliateProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pid                String?  @unique
  displayName        String?
  status             String   @default("active")
  riskFlag           Boolean  @default(false)
  tierId             String?
  tier               AffiliateTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  whitelist          Boolean  @default(false)
  blacklist          Boolean  @default(false)
  paymentInfoPending Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  applications       AffiliateApplication[]
  coupons            Coupon[]
  orders             Order[]
  commissionLedgers  AffiliateCommissionLedger[]

  @@index([status])
  @@index([blacklist, whitelist])
}

model AffiliateCommissionLedger {
  id                      String   @id @default(cuid())
  affiliateId             String
  affiliate               AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId                 String   @unique
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderTotalCents         Int
  commissionType          String
  commissionValue         Float
  commissionCents         Int
  holdDays                Int      @default(30)
  eligibleAt              DateTime
  status                  String   @default("pending")
  reversedCommissionCents Int      @default(0)
  reversalReason          String?
  reversedAt              DateTime?
  paidAt                  DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([affiliateId, status, eligibleAt])
}

model AffiliateApplication {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateId     String?
  affiliate       AffiliateProfile? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  socialLinksJson String   @default("[]")
  followerCount   Int?
  about           String?
  status          String   @default("pending")
  riskReason      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
