generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  firstName               String?
  lastName                String?
  displayName             String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  accounts                Account[]
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  productReviews          ProductReview[]
  paymentMethods          SavedPaymentMethod[]
  sessions                Session[]
  addresses               UserAddress[]
  visitorSessions         VisitorSession[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id                         String                     @id @default(cuid())
  userId                     String?
  email                      String
  status                     String
  provider                   String
  providerRef                String?
  totalCents                 Int
  currency                   String                     @default("usd")
  billingJson                String?
  shippingJson               String?
  orderNotes                 String?
  carrier                    String?
  trackingNumber             String?
  merchantOrderCode          String?
  trafficSource              String                     @default("unknown")
  merchantNotifySentAt       DateTime?
  customerShippedEmailSentAt DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  refundReason               String?
  refundAmountCents          Int?
  refundedAt                 DateTime?
  couponCode                 String?
  discountCents              Int                        @default(0)
  shippedAt                  DateTime?
  deliveredAt                DateTime?
  deliveryConfirmedBy        String?
  items                      OrderItemSnapshot[]
  user                       User?                      @relation(fields: [userId], references: [id])

  @@index([deletedAt])
  @@index([status, shippedAt])
}

model OrderItemSnapshot {
  id                  String   @id @default(cuid())
  orderId             String
  productSlug         String
  productName         String
  productImage        String?
  variantId           String?
  variantLabel        String?
  variantImage        String?
  qty                 Int
  unitPriceCents      Int
  lineTotalCents      Int
  currency            String   @default("usd")
  productSnapshotJson String?
  createdAt           DateTime @default(now())

  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productSlug])
  @@index([variantId])
}

model EmailMarketingPreference {
  id               String   @id @default(cuid())
  email            String   @unique
  unsubscribeToken String   @unique
  marketingOptOut  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserAddress {
  id         String   @id @default(cuid())
  userId     String
  type       String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  brand     String
  last4     String
  expMonth  Int?
  expYear   Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductInventory {
  id                String   @id @default(cuid())
  productSlug       String
  variantId         String   @default("")
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt

  @@unique([productSlug, variantId])
  @@index([productSlug])
}

model CatalogProduct {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  seriesSlug       String
  categoryLabel    String
  shortDescription String
  description      String
  price            Float
  compareAtPrice   Float?
  image            String
  status           String   @default("active")
  inStock          Boolean  @default(true)
  highlightsJson   String   @default("[]")
  specsJson        String   @default("[]")
  galleryJson      String   @default("[]")
  detailJson       String   @default("[]")
  variantsJson     String   @default("[]")
  promoVideoJson   String?
  storefrontCategory    String?
  storefrontSubcategory String?
  storefrontSeries      String?
  homeSpotlight         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum ProductReviewStatus {
  pending
  approved
  rejected
}

model ProductReview {
  id                String                @id @default(cuid())
  userId            String
  orderId           String?
  productSlug       String
  rating            Int
  body              String
  imageUrlsJson     String                @default("[]")
  status            ProductReviewStatus   @default(pending)
  merchantReply     String?
  merchantRepliedAt DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  appends           ProductReviewAppend[]

  @@unique([userId, orderId, productSlug])
  @@index([productSlug])
  @@index([status])
}

model ProductReviewAppend {
  id            String        @id @default(cuid())
  reviewId      String
  body          String
  imageUrlsJson String        @default("[]")
  createdAt     DateTime      @default(now())
  review        ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
}

model VisitorSession {
  id            String         @id @default(cuid())
  sessionKey    String         @unique
  userId        String?
  firstReferrer String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  landingPath   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  country       String?
  city          String?
  deviceType    String?
  browser       String?
  lastSeenAt    DateTime       @default(now())
  events        VisitorEvent[]
  user          User?          @relation(fields: [userId], references: [id])
}

model VisitorEvent {
  id          String         @id @default(cuid())
  sessionId   String
  type        String
  path        String?
  productSlug String?
  orderId     String?
  source      String?
  metaJson    String?
  createdAt   DateTime       @default(now())
  session     VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([type, createdAt])
  @@index([productSlug, createdAt])
}

model Coupon {
  id             String            @id @default(cuid())
  code           String            @unique
  amountOffCents Int
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean           @default(true)
  homeFeatured   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  quantity       Int               @default(1)
  usedCount      Int               @default(0)

  @@index([isActive, startsAt, endsAt])
  @@index([homeFeatured])
}

model AdminInboxMessage {
  id          String    @id @default(cuid())
  category    String
  status      String    @default("pending")
  sourceEmail String?
  payloadJson String    @default("{}")
  createdAt   DateTime  @default(now())
  handledAt   DateTime?
  updatedAt   DateTime  @updatedAt
  dedupeKey   String?   @unique

  @@index([category, status, createdAt])
  @@index([status, createdAt])
}

model AdminInboxReadCursor {
  id        String   @id @default(cuid())
  category  String   @unique
  readAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoTutorial {
  productSlug String   @id
  title       String
  url         String
  aspectRatio String   @default("9:16")
  updatedAt   DateTime @default(now())
  sortOrder   Int      @default(9999)
  youtubeUrl  String   @default("")
}

model BlogPost {
  id                      String    @id @default(cuid())
  slug                    String    @unique
  title                   String
  excerpt                 String    @default("")
  body                    String    @default("")
  coverImageUrl           String    @default("")
  homeCarouselSlot        Int?
  homeCarouselImageUrl    String    @default("")
  homeCarouselDescription String    @default("")
  status                  String    @default("draft")
  sortOrder               Int       @default(0)
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status, sortOrder])
  @@index([publishedAt])
  @@index([homeCarouselSlot])
}

model SiteAnnouncement {
  id              String   @id @default("default")
  enabled         Boolean  @default(false)
  message         String   @default("")
  href            String   @default("")
  slidesJson      String   @default("[]")
  backgroundColor String   @default("#0f1114")
  updatedAt       DateTime @updatedAt
}

model SiteHomeContent {
  id                  String   @id @default("default")
  heroBadge           String   @default("")
  heroTitle           String   @default("")
  heroLead            String   @default("")
  heroChip1           String   @default("")
  heroChip2           String   @default("")
  heroChip3           String   @default("")
  heroCtaShop         String   @default("")
  heroImageAlt        String   @default("")
  heroDesktopImageUrl String   @default("")
  heroMobileImageUrl  String   @default("")
  aboutHeading        String   @default("")
  aboutParagraph1     String   @default("")
  aboutParagraph2     String   @default("")
  aboutImageAlt       String   @default("")
  aboutImageUrl       String   @default("")
  spotlightBackgroundImageUrl String @default("")
  spotlightBackgroundMobileImageUrl String @default("")
  spotlightProductImageUrl String @default("")
  couponTitle             String   @default("")
  couponQuestion          String   @default("")
  couponSuccessMessage    String   @default("")
  couponTagline           String   @default("")
  couponBackgroundImageUrl String  @default("")
  certaintyHeading        String   @default("")
  certaintyLead           String   @default("")
  certaintyExtraBlocks    String   @default("")
  faqItem1Question        String   @default("")
  faqItem1Answer          String   @default("")
  faqItem2Question        String   @default("")
  faqItem2Answer          String   @default("")
  faqItem3Question        String   @default("")
  faqItem3Answer          String   @default("")
  faqItemsJson            String   @default("")
  momentsHeading              String   @default("")
  momentsLead                 String   @default("")
  momentsCard1Title           String   @default("")
  momentsCard1Description     String   @default("")
  momentsCard1DesktopImageUrl String   @default("")
  momentsCard1MobileImageUrl  String   @default("")
  momentsCard2Title           String   @default("")
  momentsCard2Description     String   @default("")
  momentsCard2DesktopImageUrl String   @default("")
  momentsCard2MobileImageUrl  String   @default("")
  updatedAt           DateTime @updatedAt
}
