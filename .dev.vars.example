# Local Wrangler preview (`npm run preview`) — copy to `.dev.vars` and fill values.
# Production secrets go in Cloudflare Workers → Settings → Variables and Secrets.
NEXTJS_ENV=development

# D1 is bound as `DB` in wrangler.jsonc — no DATABASE_URL needed on Workers.
# For local scripts (seed, migrate): DATABASE_URL=file:./dev.db in `.env.local`
# AUTH_SECRET=
# AUTH_TRUST_HOST=true
# NEXT_PUBLIC_APP_URL=http://localhost:8787
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# ... (see .env.example)
