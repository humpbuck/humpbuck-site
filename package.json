{
  "name": "humpbuck-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/prisma-generate-for-build.mjs && next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "postinstall": "node scripts/prisma-generate-for-build.mjs",
    "db:seed": "prisma db seed",
    "db:migrate": "npx tsx scripts/migrate-with-env.ts",
    "db:seed-reviews": "npx tsx prisma/seed-reviews.ts",
    "db:fix-review-avatars": "npx tsx scripts/fix-reviewer-avatars.ts",
    "db:seed-demo-orders": "npx tsx scripts/seed-admin-demo-orders.ts",
    "audit:reviews": "npx tsx scripts/audit-product-reviews-by-slug.ts",
    "r2:upload-avatar-presets": "npx tsx scripts/upload-open-peep-presets-to-r2.ts",
    "db:seed-test-review-order": "npx tsx scripts/seed-test-order-for-review.ts",
    "db:seed-inventory": "npx tsx scripts/seed-inventory.ts",
    "db:seed-catalog-products": "npx tsx scripts/seed-catalog-products.ts",
    "db:export-catalog-snapshot": "npx tsx scripts/export-catalog-snapshot.ts",
    "db:cleanup-abandoned": "npx tsx scripts/cleanup-abandoned-orders.ts",
    "geo:generate": "npx tsx scripts/generate-geo-data.ts",
    "cf-build": "cross-env CF_WORKERS_BUILD=1 opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@prisma/extension-accelerate": "^2.0.2",
    "@swc/helpers": "^0.5.23",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "country-state-city": "^3.2.1",
    "libphonenumber-js": "^1.12.42",
    "lucide-react": "^1.8.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "postcode-validator": "^3.10.15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "stripe": "^22.0.2",
    "zipcodes": "^8.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "cross-env": "^7.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
