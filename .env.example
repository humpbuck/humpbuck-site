# Database — run: npx prisma migrate dev
DATABASE_URL="file:./dev.db"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Admin panel at /admin — login with this secret (min 8 characters)
ADMIN_SECRET=""

# Public site URL (no trailing slash) — used for Stripe/PayPal return URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Webhook signing secret — https://dashboard.stripe.com/webhooks (checkout.session.completed)
STRIPE_WEBHOOK_SECRET=""

# Brevo — https://app.brevo.com (same API key as newsletter; add a verified sender for transactional email)
BREVO_API_KEY=""
BREVO_LIST_ID=""
# Must be a verified sender email in Brevo (Settings → Senders & domains)
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="HUMPBUCK"
# New order notifications (paid orders) — defaults to humpbuck@outlook.com if unset
MERCHANT_NOTIFY_EMAIL="humpbuck@outlook.com"

# PayPal — https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# sandbox | production
PAYPAL_MODE="sandbox"
# Add this URL in the PayPal app’s return URL list:
# {NEXT_PUBLIC_APP_URL}/api/checkout/paypal/return
