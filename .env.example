# Database — PostgreSQL (Neon, Supabase, local Postgres, etc.)
# Vercel: set DATABASE_URL in the project’s Environment Variables (pooled + sslmode).
# Local: paste your Neon "Connection string" (same DB as production, or a dev branch) into `.env` or `.env.local`.
# Run migrations: npm run db:migrate   (uses prisma migrate deploy)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Admin panel at /admin — login with this secret (min 8 characters)
ADMIN_SECRET=""

# Public site URL (no trailing slash) — used for Stripe/PayPal return URLs, sitemap, canonical URLs, Open Graph, and email links.
# Production (Vercel + www.humpbuck.com):
#   NEXT_PUBLIC_APP_URL="https://www.humpbuck.com"
# Optional override if you need a different canonical than APP_URL (usually omit):
#   NEXT_PUBLIC_SITE_URL="https://www.humpbuck.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# When `User.image` is empty, show Gravatar for that email (default). Set to `0` if gravatar.com is unreachable (e.g. some networks) — header/reviews use **initial letter** instead, no remote request.
# NEXT_PUBLIC_GRAVATAR_AVATARS=0

# Google Analytics 4 + Consent Mode v2 (optional). When set: gtag loads with default denied consent; user must accept for analytics. SPA route changes send virtual page views; footer shows “Cookie settings” to reopen the banner. Omit to disable analytics entirely.
# GA4 → Admin → Data streams → Web stream → 衡量 ID (starts with G-)
# Add to `.env.local` for local testing, and in your host’s env for production.
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Bump when overwriting `home/Racing car.webp` on R2 (same filename — busts browser/CDN cache). Optional; code defaults to v=3 if unset.
# NEXT_PUBLIC_R2_RACING_CAR_REV=4

# Bump when overwriting `home/RD Star.webp` on R2 (RD-ASTRAL card background). Optional; code defaults to v=2 if unset.
# NEXT_PUBLIC_R2_RD_STAR_REV=3

# Bump when overwriting `home/Spaceship.webp` on R2 (DIGI-TEMP card background). Optional; code defaults to v=1 if unset.
# NEXT_PUBLIC_R2_SPACESHIP_REV=2

# Bump when overwriting `home/HUMPBUCK-2301-first.webp` on R2 (homepage hero promo image). Optional; code defaults to v=1 if unset.
# NEXT_PUBLIC_R2_HUMPBUCK_2301_FIRST_REV=2

# Bump when overwriting `About/HUMPBUCK Promotional Video.mp4` on R2. Optional; code defaults to v=1 if unset.
# NEXT_PUBLIC_R2_ABOUT_PROMO_REV=2

# Bump when overwriting `products/RM-M03/video/HUMPBUCK-RM-M03-video.mp4` on R2 (same filename). Optional; code defaults to v=2 if unset.
# NEXT_PUBLIC_R2_RM_M03_VIDEO_REV=3

# Bump after replacing RM-M08 `HUMPBUCK-RM-M08-video.mp4` on R2. Optional; code defaults to v=1 if unset. (Video poster on PDP = first gallery slide.)
# NEXT_PUBLIC_R2_RM_M08_VIDEO_REV=2

# Bump when overwriting RM-M04 gallery/detail/variant WebPs on R2 (same keys under `products/RM-M04/`). Optional; code defaults to v=1 if unset.
# NEXT_PUBLIC_R2_RM_M04_REV=2

# PDP gallery, detail strip, variant thumbnails: live HEAD discovery on public R2 (contiguous `gallery-`, `detail-`, `variants/…-style-` indexes; cached ~5 min). Set `0` to skip (catalog URLs only), e.g. offline build.
# R2_GALLERY_DISCOVER=0

# R2 — buyer review photos (presigned PUT). Keys: reviews/{productSlug}/{userId}/{timestamp}-{id}.webp
# If R2 vars are missing: `next dev` still allows review **photos** via `public/review-uploads/` (see `lib/review-local-dev-upload.ts`).
# On Vercel you must set R2 — no local disk. Optional for `next start` on your own host: `ALLOW_REVIEW_IMAGE_LOCAL=1`.
# Profile avatars (same bucket + CORS rules): Avatar/{userId}/{timestamp}-{id}.webp (browser PUT after WebP compress)
# **Product PDP media:** the same R2 S3 API credentials are used to `ListObjects` under `products/{folder}/` so
# gallery, detail, variants, and video/ counts always match the bucket (Vercel + public `r2.dev` compatible).
# In Cloudflare dashboard → R2 bucket → Settings → CORS: allow PUT (and GET for your domain) from https://your-domain.com
# R2_ACCOUNT_ID="(Cloudflare account id, R2 overview)"
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="humpbuck-assets"
# Preset avatars: app defaults to **DiceBear** (always works). After `npm run r2:upload-avatar-presets`, set
# `NEXT_PUBLIC_AVATAR_PRESETS_FROM_R2=1` to serve the same 30 from R2. Upload: grayscale unless `AVATAR_PRESET_OPEN_PEEP_TONE=color`.
# In-browser / deployed UI tone (grayscale vs color) when using DiceBear: `NEXT_PUBLIC_AVATAR_PRESET_OPEN_PEEP_TONE=color` (optional; default gray).
# Optional if public dev URL changes (defaults to same host as `lib/r2.ts`):
# NEXT_PUBLIC_R2_PUBLIC_BASE="https://pub-….r2.dev"

# About page — Google Maps embed (optional; use one). Without either, the site shows an OpenStreetMap region preview + “Open in Google Maps” link.
# Paste the iframe `src` from Google Maps → Share → Embed a map (factory pin recommended):
# NEXT_PUBLIC_ABOUT_GOOGLE_MAP_EMBED_URL="https://www.google.com/maps/embed?pb=..."
# Or Maps Embed API key (enable “Maps Embed API” in Google Cloud Console):
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=""

# Optional — HMAC for one-tap newsletter links in emails; falls back to AUTH_SECRET if unset
# SUBSCRIBE_MAGIC_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Webhook signing secret — https://dashboard.stripe.com/webhooks (checkout.session.completed)
STRIPE_WEBHOOK_SECRET=""

# Brevo — https://app.brevo.com (same API key as newsletter; add a verified sender for transactional email)
BREVO_API_KEY=""
BREVO_LIST_ID=""
# Must be a verified sender email in Brevo (Settings → Senders & domains)
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="HUMPBUCK"
# New order notifications (paid orders) — defaults to humpbuck@outlook.com if unset
MERCHANT_NOTIFY_EMAIL="humpbuck@outlook.com"

# Customer “order shipped” email footer (optional — defaults match site copy)
# NEXT_PUBLIC_SUPPORT_EMAIL="support@humpbuck.com"
# NEXT_PUBLIC_WHATSAPP_E164="8618928160416"
# NEXT_PUBLIC_WHATSAPP_DISPLAY="+86 189 2816 0416"
# REPEAT_PURCHASE_COUPON_CODE=""
# REPEAT_PURCHASE_COUPON_NOTE="Valid on your next order; see checkout terms."

# Optional — scripts/create-fulfillment-test-order.ts (buyer email for shipped-mail test)
# FULFILLMENT_TEST_EMAIL="humpbuck@outlook.com"

# PayPal — https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# sandbox | production
PAYPAL_MODE="sandbox"
# Add this URL in the PayPal app’s return URL list:
# {NEXT_PUBLIC_APP_URL}/api/checkout/paypal/return
